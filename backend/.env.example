# Google OAuth (OPTIONAL — email/password works without this)
#
# Skip this section entirely if you only want email + password login.
#
# To enable "Sign in with Google":
# 1. Go to https://console.cloud.google.com/
# 2. Create a project (or pick an existing one)
# 3. APIs & Services → OAuth consent screen → configure (External is fine for dev)
# 4. APIs & Services → Credentials → Create Credentials → OAuth client ID
# 5. Application type: Web application
# 6. Authorized JavaScript origins: http://localhost:5173
# 7. Copy the Client ID (ends with .apps.googleusercontent.com)
# 8. Paste below AND in frontend/.env as VITE_GOOGLE_CLIENT_ID
#
# GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com

OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
# Guardrails (optional overrides — defaults are safe for dev)
# AI_RATE_LIMIT_REQUESTS=30
# AI_RATE_LIMIT_WINDOW_SECONDS=3600
# OPENAI_MAX_TOKENS=4096
# OPENAI_TIMEOUT_SECONDS=60
# MAX_REQUEST_BODY_MB=12
JWT_SECRET=change-me-in-production-use-a-long-random-string
